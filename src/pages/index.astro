---
import Layout from "../layouts/Layout.astro";

const repositoryUrl = "https://github.com/mokronos/instructmd";
const visionUrl = `${repositoryUrl}/blob/main/VISION.md`;
const homeUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;

const harnesses = [
  {
    id: "claude",
    label: "Claude Code",
    boundary: "filesystem root → working directory",
    files: [
      { path: "~/.claude/CLAUDE.md", scope: "global", state: "loaded" },
      { path: "/repo/CLAUDE.md", scope: "project", state: "loaded" },
      { path: "/repo/api/CLAUDE.local.md", scope: "local", state: "loaded" },
    ],
    context: ["Global conventions", "Repository architecture", "API-specific overrides"],
    note: "Descendant instructions activate later when files in their subtree are read.",
  },
  {
    id: "codex",
    label: "Codex CLI",
    boundary: "Git root → working directory",
    files: [
      { path: "~/.codex/AGENTS.md", scope: "global", state: "loaded" },
      { path: "/repo/AGENTS.override.md", scope: "project", state: "loaded" },
      { path: "/repo/api/AGENTS.md", scope: "directory", state: "loaded" },
    ],
    context: ["Global conventions", "Root override selected", "API directory guidance"],
    note: "One candidate wins per directory. Project instructions share a 32 KiB budget.",
  },
  {
    id: "opencode",
    label: "OpenCode",
    boundary: "worktree root → working directory",
    files: [
      { path: "~/.config/opencode/AGENTS.md", scope: "global", state: "loaded" },
      { path: "/repo/AGENTS.md", scope: "project", state: "loaded" },
      { path: "/repo/api/CLAUDE.md", scope: "fallback", state: "shadowed" },
    ],
    context: ["Global conventions", "Repository instructions", "Fallback suppressed"],
    note: "AGENTS.md suppresses CLAUDE.md in the same location; configured sources append.",
  },
];

const models = [
  ["Ancestor chain", "Claude, OpenCode, Gemini, Amp", "Can grow as files are touched"],
  ["Fixed startup chain", "Codex, pi, Qwen", "Root-to-CWD composition"],
  ["Conditional rules", "Cursor, Cline, Roo, Continue", "Globs, modes, and model choice"],
  ["Explicit context", "Junie, Kiro, Aider", "Root, scope, or user supplied"],
];
---

<Layout
  title="instruct.md — See what your coding agent sees"
  description="A CLI for visualizing how coding agents discover, order, and compose instruction files."
>
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href={homeUrl} aria-label="instruct.md home">
        <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
        <span>instruct<span>.md</span></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#how-it-works">How it works</a>
        <a href="#landscape">Landscape</a>
        <a class="nav-github" href={repositoryUrl} target="_blank" rel="noreferrer">
          <svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .7A11.3 11.3 0 0 0 8.4 22.8c.6.1.8-.3.8-.6v-2.3c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.4-1.3-5.4-5.6 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.3-5.4 5.6.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A11.3 11.3 0 0 0 12 .7Z"/></svg>
          <span>GitHub</span>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="container hero-copy">
        <div class="status-pill"><span></span> Open source · in development</div>
        <h1>See what your<br />coding agent <em>sees.</em></h1>
        <p>
          One repository. Three instruction files. Six agents. Six different answers.
          <strong>instruct.md</strong> makes the hidden context visible.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={repositoryUrl} target="_blank" rel="noreferrer">
            Follow the build
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m7 17 10-10M8 7h9v9"/></svg>
          </a>
          <a class="button button-secondary" href={visionUrl} target="_blank" rel="noreferrer">Read the vision</a>
        </div>
      </div>

      <div class="container demo-wrap" aria-label="Instruction composition example">
        <div class="demo-glow" aria-hidden="true"></div>
        <div class="demo-window">
          <div class="window-bar">
            <div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
            <div class="window-path"><span>~/work/acme/api</span><b>instruct.md</b></div>
            <span class="window-state">trace mode</span>
          </div>

          <div class="harness-tabs" role="tablist" aria-label="Select an agent harness">
            {harnesses.map((harness, index) => (
              <button
                type="button"
                role="tab"
                data-harness-tab={harness.id}
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`panel-${harness.id}`}
              >
                <span class={`harness-dot ${harness.id}`}></span>{harness.label}
              </button>
            ))}
          </div>

          {harnesses.map((harness, index) => (
            <div
              id={`panel-${harness.id}`}
              class="harness-panel"
              role="tabpanel"
              data-harness-panel={harness.id}
              hidden={index !== 0}
            >
              <div class="source-pane">
                <div class="pane-title"><span>01</span> discovered files</div>
                <div class="boundary-label">boundary: {harness.boundary}</div>
                <div class="file-list">
                  {harness.files.map((file, fileIndex) => (
                    <div class:list={["file-row", file.state === "shadowed" && "is-shadowed"]}>
                      <span class="tree-guide" aria-hidden="true">{fileIndex === harness.files.length - 1 ? "└" : "├"}</span>
                      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.5 1.5h7l4 4v9h-11v-13Z" stroke="currentColor"/><path d="M9.5 1.5v4h4" stroke="currentColor"/></svg>
                      <span class="file-path">{file.path}</span>
                      <span class="scope">{file.scope}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="flow-pane">
                <div class="pane-title"><span>02</span> composition</div>
                <div class="flow-line"><i></i><span>discover</span><i></i></div>
                <div class="flow-node">apply harness rules</div>
                <div class="flow-line"><i></i><span>order</span><i></i></div>
                <div class="flow-node accent">compose context</div>
                <p>{harness.note}</p>
              </div>

              <div class="context-pane">
                <div class="pane-title"><span>03</span> final context</div>
                <div class="context-meta">
                  <span>system-reminder</span>
                  <span>{harness.context.length} blocks</span>
                </div>
                <ol>
                  {harness.context.map((item, contextIndex) => (
                    <li class:list={[contextIndex === harness.context.length - 1 && "is-last"]}>
                      <span>{String(contextIndex + 1).padStart(2, "0")}</span>
                      <p>{item}</p>
                    </li>
                  ))}
                </ol>
                <div class="context-cursor"><span>&gt;</span><i></i></div>
              </div>
            </div>
          ))}
        </div>
        <div class="demo-caption"><span>Same directory.</span><i></i><span>Different context.</span></div>
      </div>
    </section>

    <section class="statement-section">
      <div class="container statement-grid">
        <div class="eyebrow">The problem</div>
        <p>
          Your agent reads instructions before it reads your code. But today,
          that process is invisible: filenames conflict, precedence rules differ,
          and context can change halfway through a session.
        </p>
      </div>
    </section>

    <section id="how-it-works" class="features-section">
      <div class="container">
        <div class="section-heading reveal">
          <div>
            <div class="eyebrow">One command, full provenance</div>
            <h2>Stop guessing.<br />Trace the context.</h2>
          </div>
          <p>Built to explain the real behavior of each harness, not flatten them into a fictional standard.</p>
        </div>

        <div class="feature-grid reveal">
          <article class="feature-card feature-card-wide">
            <span class="feature-number">01 / Discover</span>
            <h3>Every file. Every source.</h3>
            <p>See global, project, directory, local, imported, and lazily activated instructions in one trace.</p>
            <div class="mini-tree mono" aria-hidden="true">
              <div><span>~</span><b>CLAUDE.md</b><i>global</i></div>
              <div><span>└─ repo</span><b>AGENTS.md</b><i>project</i></div>
              <div><span>&nbsp;&nbsp;└─ api</span><b>CLAUDE.local.md</b><i>local</i></div>
            </div>
          </article>

          <article class="feature-card">
            <span class="feature-number">02 / Explain</span>
            <h3>Not just what.<br />Why.</h3>
            <p>Every inclusion, fallback, exclusion, and budget decision carries its reason.</p>
            <div class="reason-stack mono" aria-hidden="true">
              <span><i class="ok">+</i> selected <b>ancestor walk</b></span>
              <span><i class="warn">×</i> shadowed <b>fallback</b></span>
              <span><i class="info">→</i> activated <b>file access</b></span>
            </div>
          </article>

          <article class="feature-card">
            <span class="feature-number">03 / Compare</span>
            <h3>Change the harness.<br />See the delta.</h3>
            <p>Compare Claude Code, Codex, and OpenCode against the same path without changing your repository.</p>
            <div class="compare-lines mono" aria-hidden="true">
              <div><span>claude</span><i style="--width: 88%"></i><b>3 files</b></div>
              <div><span>codex</span><i style="--width: 64%"></i><b>2 files</b></div>
              <div><span>opencode</span><i style="--width: 76%"></i><b>2 + lazy</b></div>
            </div>
          </article>

          <article class="feature-card feature-card-terminal">
            <span class="feature-number">04 / Inspect</span>
            <h3>The final prompt,<br />without the mystery.</h3>
            <p>Render the ordered instruction blocks your selected harness gives the model, with provenance intact.</p>
            <div class="terminal mono" aria-label="Example command output">
              <div class="terminal-bar"><span></span><span></span><span></span><b>~/work/acme</b></div>
              <div class="terminal-body">
                <p><span>$</span> instructmd trace --codex ./api</p>
                <p class="dim">boundary&nbsp;&nbsp; /work/acme <i>git root</i></p>
                <p><b>01</b> ~/.codex/AGENTS.md <i>global</i></p>
                <p><b>02</b> ./AGENTS.md <i>project</i></p>
                <p><b>03</b> ./api/AGENTS.override.md <i>directory</i></p>
                <p class="success">✓ composed 3 blocks · 4.8 KiB</p>
                <p><span>$</span><em></em></p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="landscape" class="landscape-section">
      <div class="container landscape-grid reveal">
        <div class="landscape-copy">
          <div class="eyebrow">The instruction landscape</div>
          <h2>There is no one<br /><em>AGENTS.md</em> standard.</h2>
          <p>
            We traced official documentation and source across 18 coding agents.
            Their loaders fall into four broad families, each with different boundaries,
            timing, and composition rules.
          </p>
          <a href={visionUrl} target="_blank" rel="noreferrer">
            See the product vision
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m7 17 10-10M8 7h9v9"/></svg>
          </a>
        </div>

        <div class="model-list">
          {models.map((model, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div><h3>{model[0]}</h3><p>{model[1]}</p></div>
              <small>{model[2]}</small>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="principles-section">
      <div class="container principles-grid reveal">
        <div>
          <span class="principle-mark">P</span>
          <h3>Precise, not approximate.</h3>
          <p>Evaluator behavior is pinned to harness versions and evidence is marked as documented, source-observed, or unknown.</p>
        </div>
        <div>
          <span class="principle-mark">S</span>
          <h3>Small, fast, local.</h3>
          <p>A focused CLI designed to inspect your filesystem without turning instruction files into a management platform.</p>
        </div>
        <div>
          <span class="principle-mark">O</span>
          <h3>Open from day zero.</h3>
          <p>The research, product direction, and implementation live in public. Follow along or challenge an assumption.</p>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-grid" aria-hidden="true"></div>
      <div class="container cta-content reveal">
        <span class="eyebrow">Work in progress</span>
        <h2>Make the invisible<br /><em>inspectable.</em></h2>
        <p>instruct.md is being built in the open. Watch the repository for the first usable release.</p>
        <div class="hero-actions">
          <a class="button button-primary" href={repositoryUrl} target="_blank" rel="noreferrer">Watch on GitHub <span>↗</span></a>
          <a class="button button-secondary" href={visionUrl} target="_blank" rel="noreferrer">Read the vision</a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-inner">
      <a class="brand" href={homeUrl}><span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span><span>instruct<span>.md</span></span></a>
      <p>Built to explain, not abstract away.</p>
      <div><a href={repositoryUrl}>GitHub</a><a href={visionUrl}>Vision</a></div>
    </div>
  </footer>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-harness-tab]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-harness-panel]"));

    const selectHarness = (id: string) => {
      for (const tab of tabs) {
        tab.setAttribute("aria-selected", tab.dataset.harnessTab === id ? "true" : "false");
      }
      for (const panel of panels) {
        panel.hidden = panel.dataset.harnessPanel !== id;
      }
    };

    for (const tab of tabs) {
      tab.addEventListener("click", () => selectHarness(tab.dataset.harnessTab ?? "claude"));
    }

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const reveals = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
    if (!reduceMotion && "IntersectionObserver" in window) {
      for (const element of reveals) element.classList.add("reveal-pending");
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("reveal-visible");
            observer.unobserve(entry.target);
          }
        }
      }, { threshold: 0.12, rootMargin: "0px 0px -5%" });
      for (const element of reveals) observer.observe(element);
    }
  </script>
</Layout>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: rgba(11, 13, 12, 0.78);
    backdrop-filter: blur(16px);
  }

  .nav-shell {
    display: flex;
    height: 62px;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .brand > span:last-child > span {
    color: var(--ink-3);
  }

  .brand-mark {
    display: grid;
    width: 22px;
    height: 22px;
    grid-template-columns: repeat(3, 1fr);
    align-items: end;
    gap: 2px;
    padding: 4px;
    border: 1px solid var(--line-strong);
    border-radius: 5px;
  }

  .brand-mark i {
    display: block;
    background: var(--acid);
  }

  .brand-mark i:nth-child(1) { height: 6px; }
  .brand-mark i:nth-child(2) { height: 12px; }
  .brand-mark i:nth-child(3) { height: 9px; }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
    color: var(--ink-2);
    font-size: 13px;
  }

  nav a {
    transition: color 160ms ease;
  }

  nav a:hover { color: var(--ink); }

  .nav-github {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink);
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 110px 0 78px;
  }

  .hero-grid,
  .cta-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 60% 52% at 50% 22%, black, transparent 80%);
    opacity: 0.48;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 28px;
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-2);
    background: rgba(16, 19, 17, 0.72);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .status-pill span {
    width: 6px;
    height: 6px;
    border-radius: 99px;
    background: var(--acid);
    box-shadow: 0 0 0 4px var(--acid-soft);
    animation: statusPulse 2.4s ease-in-out infinite;
  }

  .hero h1,
  .cta-content h2 {
    max-width: 980px;
    margin: 0 auto;
    font-size: clamp(52px, 8.2vw, 104px);
    font-weight: 500;
    letter-spacing: -0.065em;
    line-height: 0.92;
  }

  .hero h1 em,
  .cta-content h2 em,
  .landscape-copy h2 em {
    color: var(--acid);
    font-style: normal;
  }

  .hero-copy > p {
    max-width: 630px;
    margin: 30px auto 0;
    color: var(--ink-2);
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.55;
    text-wrap: balance;
  }

  .hero-copy > p strong {
    color: var(--ink);
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 34px;
  }

  .demo-wrap {
    position: relative;
    z-index: 2;
    margin-top: 90px;
  }

  .demo-glow {
    position: absolute;
    inset: 10% 15%;
    filter: blur(70px);
    background: rgba(216, 255, 121, 0.13);
  }

  .demo-window {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    border-radius: 14px;
    background: rgba(9, 11, 10, 0.96);
    box-shadow: 0 45px 100px -45px #000, 0 0 0 1px rgba(0, 0, 0, 0.8);
  }

  .window-bar {
    display: grid;
    min-height: 46px;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 16px;
    border-bottom: 1px solid var(--line);
    background: #111411;
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .window-dots { display: flex; gap: 6px; }
  .window-dots span { width: 8px; height: 8px; border-radius: 50%; background: #3a3f3a; }
  .window-path { display: flex; align-items: center; gap: 8px; color: var(--ink-3); }
  .window-path b { color: var(--ink-2); font-weight: 400; }
  .window-state { justify-self: end; color: var(--acid); text-transform: uppercase; letter-spacing: 0.08em; }

  .harness-tabs {
    display: flex;
    gap: 4px;
    padding: 10px;
    border-bottom: 1px solid var(--line);
    background: #0d100e;
  }

  .harness-tabs button {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 11px;
    border: 1px solid transparent;
    border-radius: 5px;
    color: var(--ink-3);
    background: transparent;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .harness-tabs button:hover { color: var(--ink-2); }
  .harness-tabs button[aria-selected="true"] { border-color: var(--line); color: var(--ink); background: var(--panel-raised); }

  .harness-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-3); }
  .harness-dot.claude { background: var(--amber); }
  .harness-dot.codex { background: var(--ink); }
  .harness-dot.opencode { background: var(--blue); }

  .harness-panel {
    display: grid;
    min-height: 390px;
    grid-template-columns: 1.15fr 0.82fr 1.05fr;
  }

  .harness-panel[hidden] { display: none; }
  .source-pane, .flow-pane, .context-pane { min-width: 0; padding: 24px; }
  .flow-pane, .context-pane { border-left: 1px solid var(--line); }

  .pane-title {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 23px;
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pane-title span { color: var(--acid); }
  .boundary-label { margin-bottom: 20px; color: var(--ink-3); font-family: var(--font-mono); font-size: 9px; }

  .file-list { display: flex; flex-direction: column; gap: 3px; }
  .file-row {
    display: grid;
    min-height: 50px;
    grid-template-columns: 16px 15px minmax(0, 1fr) auto;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    border: 1px solid var(--line);
    border-radius: 5px;
    color: var(--ink-2);
    background: rgba(244, 241, 232, 0.025);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .file-row.is-shadowed { opacity: 0.42; text-decoration: line-through; }
  .tree-guide { color: var(--ink-3); }
