---
import Layout from "../layouts/Layout.astro";

const repositoryUrl = "https://github.com/mokronos/instructmd";
const homeUrl = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/`;

const harnesses = [
  {
    id: "claude",
    label: "Claude Code",
    files: [
      ["~/.claude/CLAUDE.md", "global", "loaded"],
      ["/repo/CLAUDE.md", "repository", "loaded"],
      ["/repo/api/CLAUDE.local.md", "working directory", "loaded"],
    ],
    note: "Walks the ancestor chain into the working directory.",
  },
  {
    id: "codex",
    label: "Codex",
    files: [
      ["~/.codex/AGENTS.md", "global", "loaded"],
      ["/repo/AGENTS.override.md", "repository", "loaded"],
      ["/repo/api/AGENTS.md", "working directory", "loaded"],
    ],
    note: "Shows the selected candidate and its precedence at each scope.",
  },
  {
    id: "opencode",
    label: "OpenCode",
    files: [
      ["~/.config/opencode/AGENTS.md", "global", "loaded"],
      ["/repo/AGENTS.md", "repository", "loaded"],
      ["/repo/api/AGENTS.md", "working directory", "loaded"],
      ["/repo/api/CLAUDE.md", "shadowed", "shadowed"],
    ],
    note: "Makes a same-directory fallback that lost precedence explicit.",
  },
];
---

<Layout
  title="instructmd — Explain your coding agent's instruction stack"
  description="Inspect the exact startup order of AGENTS.md and CLAUDE.md files, including why each instruction file was loaded or shadowed."
>
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href={homeUrl} aria-label="instructmd home">
        <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
        <span>instruct<span>.md</span></span>
      </a>
      <a class="github" href={repositoryUrl} target="_blank" rel="noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .7A11.3 11.3 0 0 0 8.4 22.8c.6.1.8-.3.8-.6v-2.3c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.4-1.3-5.4-5.6 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.3-5.4 5.6.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A11.3 11.3 0 0 0 12 .7Z"/></svg>
        GitHub
      </a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-copy">
        <p class="kicker">Startup instruction resolution</p>
        <h1>Know what gets<br /><em>into context.</em></h1>
        <p class="intro">
          Coding agents stack <code>AGENTS.md</code> and <code>CLAUDE.md</code> from global,
          repository, and working-directory scopes. instructmd shows the exact startup order —
          and why each file was loaded or shadowed.
        </p>
        <div class="install-command">
          <code>cargo install instructmd</code>
          <button type="button" data-copy-command aria-label="Copy cargo install instructmd">
            <span data-copy-label>Copy</span>
          </button>
          <span class="sr-only" aria-live="polite" data-copy-status></span>
        </div>
      </div>
    </section>

    <section class="demonstration" aria-labelledby="demo-title">
      <div class="container">
        <div class="section-heading">
          <p class="kicker">One directory, visible layers</p>
          <h2 id="demo-title">Resolution, not guesswork.</h2>
        </div>
        <div class="demo-window">
          <div class="window-bar"><span aria-hidden="true"></span><code>~/work/acme/api</code><b>startup trace</b></div>
          <div class="harness-tabs" role="tablist" aria-label="Select an agent">
            {harnesses.map((harness, index) => (
              <button type="button" role="tab" data-harness-tab={harness.id} aria-selected={index === 0 ? "true" : "false"} aria-controls={`panel-${harness.id}`} tabindex={index === 0 ? "0" : "-1"}>{harness.label}</button>
            ))}
          </div>
          {harnesses.map((harness, index) => (
            <div id={`panel-${harness.id}`} class="harness-panel" role="tabpanel" data-harness-panel={harness.id} hidden={index !== 0} tabindex="0">
              <div class="trace-label"><span>resolved startup stack</span><span>global → repository → working directory</span></div>
              <ol class="layer-list">
                {harness.files.map(([path, scope, state], fileIndex) => (
                  <li class:list={[state === "shadowed" && "is-shadowed"]}>
                    <span class="layer-number">{String(fileIndex + 1).padStart(2, "0")}</span>
                    <code>{path}</code>
                    <span class="layer-scope">{scope}</span>
                    <span class="layer-state">{state === "shadowed" ? "not loaded — AGENTS.md wins here" : "loaded"}</span>
                  </li>
                ))}
              </ol>
              <p class="trace-note">Why: {harness.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="support" aria-label="Supported agents">
      <div class="container"><p><strong>Supports</strong> OpenCode, Claude Code, OpenAI Codex CLI, pi, Gemini CLI, Amp, goose, and Qwen Code.</p></div>
    </section>
  </main>

  <footer><div class="container footer-inner"><span>instruct<span>.md</span></span><a href={repositoryUrl} target="_blank" rel="noreferrer">GitHub</a></div></footer>

  <script>
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-harness-tab]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-harness-panel]"));
    const selectHarness = (id: string, focus = false) => {
      tabs.forEach((tab) => {
        const selected = tab.dataset.harnessTab === id;
        tab.setAttribute("aria-selected", String(selected));
        tab.tabIndex = selected ? 0 : -1;
        if (selected && focus) tab.focus();
      });
      panels.forEach((panel) => { panel.hidden = panel.dataset.harnessPanel !== id; });
    };
    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => selectHarness(tab.dataset.harnessTab ?? "claude"));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();
        const next = event.key === "Home" ? 0 : event.key === "End" ? tabs.length - 1 : (index + (event.key === "ArrowRight" ? 1 : -1) + tabs.length) % tabs.length;
        selectHarness(tabs[next].dataset.harnessTab ?? "claude", true);
      });
    });

    const copyButton = document.querySelector<HTMLButtonElement>("[data-copy-command]");
    const copyLabel = document.querySelector<HTMLElement>("[data-copy-label]");
    const copyStatus = document.querySelector<HTMLElement>("[data-copy-status]");
    copyButton?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("cargo install instructmd");
        if (copyLabel) copyLabel.textContent = "Copied";
        if (copyStatus) copyStatus.textContent = "Command copied to clipboard.";
      } catch {
        if (copyStatus) copyStatus.textContent = "Copy failed. Select the command and copy it manually.";
      }
      window.setTimeout(() => { if (copyLabel) copyLabel.textContent = "Copy"; }, 1800);
    });
  </script>
</Layout>

<style>
  .site-header { border-bottom: 1px solid var(--line); background: rgba(11, 13, 12, .84); }
  .nav-shell, .footer-inner { min-height: 72px; display: flex; align-items: center; justify-content: space-between; }
  .brand, footer span { display: inline-flex; align-items: center; gap: 9px; font: 500 17px var(--font-mono); letter-spacing: -.06em; }
  .brand > span:last-child span, footer span span { color: var(--acid); }
  .brand-mark { display: flex; gap: 3px; align-items: end; height: 16px; }
  .brand-mark i { width: 3px; background: var(--acid); } .brand-mark i:nth-child(1) { height: 7px; } .brand-mark i:nth-child(2) { height: 13px; } .brand-mark i:nth-child(3) { height: 10px; }
  .github { display: inline-flex; align-items: center; gap: 7px; color: var(--ink-2); font: 500 14px var(--font-mono); } .github:hover, footer a:hover { color: var(--acid); }
  .hero { padding: clamp(84px, 14vw, 176px) 0 clamp(74px, 11vw, 140px); }
  .hero-copy { max-width: 820px; }
  .kicker { color: var(--acid); font: 500 12px var(--font-mono); letter-spacing: .1em; text-transform: uppercase; }
  h1, h2 { font-weight: 500; letter-spacing: -.065em; line-height: .98; } h1 { margin-top: 22px; font-size: clamp(48px, 8.3vw, 112px); } h1 em { color: var(--acid); font-style: normal; } h2 { font-size: clamp(32px, 4.6vw, 58px); }
  .intro { max-width: 650px; margin-top: 30px; color: var(--ink-2); font-size: clamp(16px, 2vw, 20px); line-height: 1.55; } .intro code { color: var(--ink); font: 500 .88em var(--font-mono); }
  .install-command { max-width: 510px; min-height: 62px; display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 42px; padding: 8px 8px 8px 20px; border: 1px solid rgba(216,255,121,.64); background: rgba(216,255,121,.075); box-shadow: 0 20px 70px -42px var(--acid); } .install-command code { font: 500 16px var(--font-mono); color: var(--acid); } .install-command button { min-height: 44px; border: 0; padding: 0 17px; color: var(--bg-deep); background: var(--acid); cursor: pointer; font: 600 14px var(--font-sans); } .install-command button:hover { background: #ebffb4; }
  .demonstration { padding: clamp(60px, 9vw, 112px) 0; border-top: 1px solid var(--line); background: linear-gradient(90deg, rgba(216,255,121,.035), transparent 45%); } .section-heading { margin-bottom: 35px; } .section-heading h2 { margin-top: 14px; }
  .demo-window { overflow: hidden; border: 1px solid var(--line-strong); background: var(--panel); box-shadow: 0 30px 90px -55px #000; } .window-bar { min-height: 48px; display: flex; align-items: center; gap: 11px; padding: 0 18px; border-bottom: 1px solid var(--line); color: var(--ink-3); font: 12px var(--font-mono); } .window-bar > span { width: 8px; height: 8px; border-radius: 50%; background: var(--acid); } .window-bar b { margin-left: auto; color: var(--ink-2); font-weight: 400; }
  .harness-tabs { display: flex; overflow-x: auto; border-bottom: 1px solid var(--line); } .harness-tabs button { flex: 1 0 130px; min-height: 52px; border: 0; border-right: 1px solid var(--line); color: var(--ink-3); background: transparent; cursor: pointer; font: 500 14px var(--font-mono); } .harness-tabs button[aria-selected="true"] { color: var(--bg-deep); background: var(--acid); }
  .harness-panel { padding: clamp(20px, 4vw, 46px); } .trace-label { display: flex; justify-content: space-between; gap: 20px; color: var(--ink-3); font: 12px var(--font-mono); text-transform: uppercase; letter-spacing: .06em; } .trace-label span:first-child { color: var(--acid); }
  .layer-list { margin-top: 20px; padding: 0; border-top: 1px solid var(--line); list-style: none; } .layer-list li { display: grid; grid-template-columns: 40px minmax(190px, 1fr) 145px minmax(180px, .8fr); gap: 14px; align-items: center; padding: 18px 0; border-bottom: 1px solid var(--line); font-size: 15px; } .layer-number { color: var(--acid); font: 13px var(--font-mono); } .layer-list code { overflow-wrap: anywhere; color: var(--ink); font: 14px var(--font-mono); } .layer-scope, .layer-state { color: var(--ink-2); } .layer-state { font-size: 14px; } .is-shadowed { opacity: .55; } .is-shadowed .layer-state { color: var(--amber); }
  .trace-note { margin-top: 18px; color: var(--ink-2); font-size: 15px; } .support { padding: 46px 0; border-top: 1px solid var(--line); } .support p { color: var(--ink-2); font-size: 16px; } .support strong { color: var(--acid); font: 500 13px var(--font-mono); letter-spacing: .06em; text-transform: uppercase; } footer { border-top: 1px solid var(--line); } .footer-inner { min-height: 78px; color: var(--ink-3); font-size: 14px; } footer a { font: 14px var(--font-mono); }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  @media (max-width: 700px) { .hero { padding-top: 74px; } .layer-list li { grid-template-columns: 29px 1fr; gap: 8px 12px; } .layer-scope { grid-column: 2; } .layer-state { grid-column: 2; } .trace-label span:last-child { display: none; } }
  @media (max-width: 430px) { .nav-shell { min-height: 62px; } .install-command { padding-left: 14px; } .install-command code { font-size: 13px; } .install-command button { padding: 0 12px; } .window-bar b { display: none; } }
</style>
